# Server Configuration
PORT=5001
NODE_ENV=production

# Database
# Replace with your MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/curavet?retryWrites=true&w=majority

# Security
# Generate a strong secret (e.g., openssl rand -base64 32)
JWT_SECRET=your_super_secret_jwt_key_here

# Frontend URL (for CORS)
FRONTEND_URL=https://curavet.vercel.app

# Cloudinary (Production Image Storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Optional - for real emails)
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=your_user
# SMTP_PASS=your_pass
